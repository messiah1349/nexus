# Postgres (matches docker-compose.yml defaults)
POSTGRES_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexus

# LLM provider + model. Each provider has a sensible DEFAULT_MODEL; only
# set LLM_MODEL if you want to override it.
#   anthropic → claude-sonnet-4-6 (default)
#   gemini    → gemini-2.5-flash (default)
LLM_PROVIDER=anthropic
# LLM_MODEL=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=  # without the @, used to render the Login Widget

# Web frontend
# Generate a strong secret for the session cookie signer in production:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
WEB_SESSION_SECRET=dev-only-insecure-change-me
# Set to true ONLY for local testing — exposes /auth/dev which logs in any
# telegram_id without verification.
WEB_DEV_AUTH=false

# Logging
LOG_LEVEL=INFO
ENV=dev
