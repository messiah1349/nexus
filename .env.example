# Postgres (matches docker-compose.yml defaults)
POSTGRES_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexus

# LLM provider + model (provider-agnostic interface; only `anthropic` implemented in v1)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Telegram (Phase 4)
TELEGRAM_BOT_TOKEN=

# Logging
LOG_LEVEL=INFO
ENV=dev
